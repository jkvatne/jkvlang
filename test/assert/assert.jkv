

func f(a Bool, c I32) I32 {
    if a ? c+=2 : c+=1
    return c
}

func main() {
    printf("f(true,5)=%d\n", f(true,5))
    assert(f(true, 5)==7)

    z = f(true, 5)
    printf("z=%d;  Should be 7\n", z)
    assert(z==7, "Should not be printed, assert(z==%d)", z)

    printf("Goodbye from jkv\n")
}
