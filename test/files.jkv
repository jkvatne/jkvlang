/*
func test(f I32, cnt I32) String, I32, I32 {
    n = I32(13)
    buffer = "abcd"
    return buffer, n, 14
}
*/

func read_string(f I32, cnt I32) String {
    buf=new(String,cnt)
    ok = read_file(f, cptr(buf), cnt, lptr(buf), 0)
    return buf
}

func main() {
    // Test write to file
    fn = "./test.txt"
    n = I32(0)
    text = "Hello World!"
    f = create_file(cptr(fn), 0xc0000000, 0,0, 4, 128, 0)
    print("create_file handle=%d", f)
    ok = write_file(f, cptr(text), 13, ptr(n), 0)
    assert(ok==1)
    assert(n==13)
    assert(I64(f)!=-1)
    close_file(f)

    //  Test read back file using read_string
    f2 = create_file(cptr(fn), 0xc0000000, 0,0, 4, 128, 0)
    buffer = read_string(f2, 12)
    print("Buffer=%s", buffer)
    assert(buffer=="Hello World!")

/*
    // 4. Test open invalid name
