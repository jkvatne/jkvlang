
type Age = U8

type Name = struct {
    id String
    first String
    last String
}

 type Person = struct {
    id String
    name Name
    age Age
 }

func main() {
    j=4
    print("j=%d", j)
    j=j-1
    print("j=%d", j)

    p = new(Person)
    p.age = 70
    print("age=%d", p.age)

    n = new(Name)
    n.first = "Jan Kåre"
    n.last = "Vatne"

    p.name = n  // NB: Destructive read. n can now not be accessed.
    //n.last[2] = 'x' // Will fail because of destructive read

    print("p.name=%s, %s", p.name.last, p.name.first)
    print("p.name[3]=0x%x", p.name.last[3])

    p.name.last[j]='x'  // 0x78
    print("p.name=%s, %s", p.name.last, p.name.first)

}