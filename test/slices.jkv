
type Age = U8

type Name = struct {
    id String
    first String
    last String
}

 type Person = struct {
    id String
    name Name
    age Age
 }

func main() {
    j=2
    j=j+1
    p = new(Person)
    p.age = 70
    print("age=%d", p.age)

    n = new(Name)
    n.first = "Jan Kåre"
    n.last = "Vatne"

    p.name = n  // NB: Destructive read. n can now not be accessed.
    //n.last[2] = 'x' // Will fail because of destructive read

    print("p.name.last=%s, p.name.first=%s", p.name.last, p.name.first)
    print("j=%d, p.name.last[j]=0x%x", j, p.name.last[j])
    print("p.name.last[3]=0x%x", p.name.last[3])
    assert(p.name.last[j]=='x')

    k=-1
    print("j+k=%d", j+k)
    p.name.last[j+k]='x'  // 0x78
    assert(p.name.last=="Vaxne")
    print("p.name.last=%s", p.name.last)

}