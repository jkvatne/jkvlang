
func f0(s String) String {
    return "f0 "+s
}

func f1(s String) String {
    t = "f1 "
    return t+s
}

func f2(s String) String {
    t = " f2"
    return s+t
}

func f3(s String, t String) String {
  return s+t
}

func g1(a String, b String, c String) String {
    return a+b+c
}

func g2(s String, t String) String {
    return s+t
}

func main() {
    // Test asserts that fail compare strings that are different size or different content
    assert(f0("xyz")=="f0 xyz", "Should not fail")
    assert(f0("axyz")=="f0 xyz", "Intentionally fail")
    invert_err()
    assert(f0("ayz")=="f0 xyz", "Intentionally fail")
    invert_err()

    // Test string compare equal and not equal
    u = "abc"
    v = "abcs"
    s = "abc"
    assert(u!=v, "Fail 18a")
    assert(u!=s, "Intentional fail 18b")
    invert_err()
    assert(u==v, "Intentional fail 18c")
    invert_err()
    assert(u==s, "Fail 18d")

    // Test concat three strings and assign to local variable
    s = "Hello "
    t = "World "
    u = "and goodbye!"
    w = s+t+u
    assert(w=="Hello World and goodbye!", "Failed 1")
    assert(s=="Hello ", "Failed access to old s")

    // Test concatenated function calls
    w = f1("F1")+f2("F2")
    assert(w=="f1 F1F2 f2", "Failed 5")

    // Test nested function calls
    w = f1(f2("F1F2"))+f2("F2")

    assert(w=="f1 F1F2 f2F2 f2", "Failed 6")


    // Test nested functions
    w = g1("abc", g2("def", "ghi"),"jkl")
    assert(w=="abcdefghijkl", "Failed 9")
    w = g2("abc","def")
    assert(w=="abcdef", "Failed 9")

    // Test concat two variables
    s = "Hello "
    t = "World "
    u = s + t
    assert(u=="Hello World ", "Failed 10")

    // Test freeing of temporary object returned from f0
    w = f0("xyz")
    assert(w=="f0 xyz", "Failed 11")

    // Test calling function in actual parameter
    assert(f0("xyz")=="f0 xyz", "Failed 12")

    // Test concatenation of constant and variable
    s = "xyz"
    v = "pre-" + s
    assert(v=="pre-xyz","Failed 13")

    // Test concatenation of variable and constant overwriting old local var
    s = "xyz"
    v = s+"-post"
    assert(v=="xyz-post","Failed 14")

    // Test concatenation of constant and constant
    w = "pre-"+"post"
    assert(w=="pre-post","Failed 15")

    // Test calling functions with string parameters
    assert(f0("xyz")=="f0 xyz","Failed 16")
    assert(f1("xyz")=="f1 xyz","Failed 16")
    assert(f2("xyz")=="xyz f2","Failed 16")

    // Test string compare equal
    u = "abc"
    v = "abc"
    assert(u=="abc","Failed 17a")
    assert(u==v,"Failed 17b")
    assert(v==u,"Failed 17c")


    // Test if equal
    u = "abc"
    v = "abx"
    if u==v {
        assert(false,"Failed 19")
    }
    v = "abc"
    if u==v {
        // Expected equal
    }

    // Test string compare with literal
    u = "abc"
    assert(u!="abb", "Failed 20a")
    assert("abca"!=u, "Failed 20b")

}
