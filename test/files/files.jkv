
func test(f I32, cnt I32) String, I32, I32 {
    n = I32(13)
    buffer = "abcd"
    return buffer, n, 14
}

func read_string(f I32, cnt I32) String {
    buffer=new(String,cnt)
    ok = read_file(f, cptr(buffer), cnt, lptr(buffer), 0)
    return buffer
}

func main() {
    printf("1. Test returning 3 results\n")
    buf, n, m = test(11, 12)
    assert(n==13)
    assert(m==14)
    assert(buf=="abcd")

    printf("2. Test write to file\n")
    fn = "./test.txt"
    n = I32(0)
    text = "Hello World!\n"
    f = create_file(cptr(fn), 0xc0000000, 0,0, 4, 128, 0)
    printf("create_file handel=%d\n", f)
    ok = write_file(f, cptr(text), 13, ptr(n), 0)
    assert(ok==1)
    assert(n==13)
    assert(I64(f)!=-1)
    close_file(f)

    printf("3. Test read back file using read_string\n")
    f = create_file(cptr(fn), 0xc0000000, 0,0, 4, 128, 0)
    buffer = read_string(f, 12)
    assert(buffer=="Hello World!")

    printf("4. Test open invalid name\n")
    fn = ":::"
    f = create_file(cptr(fn), 0xc0000000, 0,0, 4, 128, 0)
    invert_err()
    assert(I64(f)==-1)
}
