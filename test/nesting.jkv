
func foo(a F64, b F64) F64 {
    return (a+b)*(a-b)
}

func bar(a F64, b F64) F64 {
    return 1+foo(a,b)
}

func main() {
    c=3.3
    x=1
    y=x+c
    assert(y==4.3)

    a=1.1
    b=2.2
    d=0.0
    if a>1.0 {
        if c<10.0 {
            d=bar(a,b)
            assert(d>-2.631 && d<-2.629, "d=%f", d)
        }
    } else {
        d=foo(b,c)
    }
    assert(d>-2.631 && d<-2.629)
    z = d+2.63
    assert(z>-1e-15 && z<1e-15, "Failed z=%g", z)
}
