func f(x I32, y I32) I32 {
   return x+y
}

func g(x I32, y I32) I32 {
   return x*y
}

func main() {
  w = f(3, g(4,5))
  assert(w==23)
  printf("w=%d\n",w)
  w = g(1,2)
  assert(w==2)
  printf("w=%d\n",w)
}

