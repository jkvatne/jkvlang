
func gg(a Bool, c I32) I32 {
    if a ? c+=2 : c+=1
    return c
}

func test_g()  {
    r = gg(true, 30)
    assert(r==32)
}

func sum(x I32, y I32) I32 {
   return x+y
}

func mpy(x I32, y I32) I32 {
   return x*y
}

func f2() I32 {
    return sum(2,3)+mpy(4,5)  // = (2+3) + (4*5) = 25
}

func main() {
    printf("f2()=%d\n", f2())
    assert(f2()==25,"Failed f2()==25, got %d", f2())
    w = sum(3, mpy(4,5))   // = 23
    assert(w==23)
    printf("w=%d\n",w)
    w = mpy(3,4)
    printf("w=%d\n",w)   // 12
    assert(w==12)
    printf("gg(true, f2())=%d\n", gg(true,f2()))  // 277
    assert(gg(true, f2())==27)
    test_g()
}
