
func gg(a Bool, c I32) I32 {
    if a ? c+=2 : c+=1
    return c
}

func test_g()  {
    r = gg(true, 30)
    assert(r==32)
}

func f(x I32, y I32) I32 {
   return x+y
}

func g(x I32, y I32) I32 {
   return x*y
}

func f2() I32 {
    return f(2,3)+g(4,5)
}

func main() {
    printf("f2()=%d\n", f2())
    assert(f2()==25,"Failed f2()")
    w = f(3, g(4,5))
    assert(w==23)
    printf("w=%d\n",w)
    w = g(1,2)
    printf("w=%d\n",w)
    assert(w==2)
    printf("gg(true, f2())=%d\n", gg(true,f2()))
    assert(gg(true, f2())==27)
    test_g()
}
