
func f2() I32 {
    z=3
    z*=8
    z+=4     // = 28
    s = 24
    s = s/6  // = 4
    return s+z  // = 32
}

func g(a Bool, c I32) I32 {
    if a ? c+=2 : c+=1
    return c
}

func test_g()  {
    r = g(true, 30)
    assert(r==32)
}

func main() {
    printf("f2()=%d\n", f2())
    assert(f2()==32)
    printf("g(true,5)=%d\n", g(true,5))
    assert(g(true, 5)==7)
    test_g()
}


