func f(x I32, y I32) I32 {
   return x+y
}

func g(x I32, y I32) I32 {
   return x*y
}

func f2() I32 {
    return f(2,3)+g(4,5)
}

func gg(a Bool, c I32) I32 {
    if a ? c+=2 : c+=1
    return c
}

func test_g()  {
    r =0
   // r = gg(true, 30)
   // assert(r==32)
}

func main() {
    printf("f2()=%d\n", f2())
    w = f(3, g(4,5))
    assert(w==23)
    printf("w=%d\n",w)
    w = g(1,2)
    assert(w==2)
    printf("w=%d\n",w)
    printf("gg(true,5)=%d\n", gg(true,6))
    assert(f2()==32)
    assert(gg(true, 5)==7)
    test_g()
}
