
func f0(s String) String {
    return "f0 "+s
}

func f1(s String) String {
    t = "f1 "
    u = t+s
    return u
}

func f2(s String) String {
    t = " f2"
    return s+t
}

func f3(s String, t String) String {
  return s+t
}

func main() {
    // Test concat
    s = "Hello "
    t = "World "
    v = s + t
    printf("v=%s\n", v)
    printf("Starting string tests\n")

    // Test concatenation of variable and constant
    s = "xyz"
    u = "pre-" + s
    assert(u=="pre-xyz")
    v = s+"-post"
    assert(v=="xyz-post")
    w = "pre-"+"post"
    assert(w=="pre-post")

    // Test calling functions with string parameters
    assert(f0("xyz")=="f0 xyz")
    assert(f1("xyz")=="f1 xyz")
    assert(f2("xyz")=="xyz f2")

    // Test string compare
    a = "abc"
    assert(a=="abc", "Failed a==abc")
    b = "abc"
    assert(a==b, "a==b failed")
    assert(b==a, "b==a failed")
    c = "abcs"
    assert(a!=c, "a!=c failed")
    assert(c!=a, "c!=a failed")
    c = "abx"
    assert(a!=c, "a!=c failed")
    c = "ab"
    assert(a!=c, "a!=c failed")
    if a==c {
        assert(false,"Failed compare strings")
    }

    // Test concat
    s = "Hello "
    t = "World "
    v = s + t
    printf("v=%s\n", v)
    u = "and goodbye!"
    w = s + t + u
    printf("w=%s\n", w)
    assert(w=="Hello World and goodbye!", "s+t+u failed")
    printf("Ending string tests\n")
}
