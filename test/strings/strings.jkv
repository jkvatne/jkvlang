func f0(s String) String {
    return "f0 "+s
}

func main() {

    printf("1. Test concat two variables\n")
    s = "Hello "
    t = "World "
    u = s + t
    assert(u=="HellosWorld ")

    printf("2. Test freeing of temporary object returned from f0\n")
    assert(f0("xyz")=="f0 xyz")

    printf("3. Test concatenation of constant and variable\n")
    s = "xyzzzzzzzzzzzzzzzzzzzzz"
    v = "pre-" + s
    assert(v=="pre-xyz")

    printf("4. Test concatenation of variable and constant\n")
    // This is current causing leaked memory because v has already a object
    // And that is overwritten, but not freed. Assigning to an existing variable must free the old object if it is owned.
    v = s+"-post"
    assert(v=="xyz-post")

