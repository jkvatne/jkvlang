
func main() {
    printf("Starting string tests\n")
    a = "abc"
    b = "abc"
    assert(a==b, "a==b failed")
    a = "abc"
    b = "xxxx"
    if a==b {
        assert(false,"Failed compare strings")
    }
    // Test concat
    s = "Hello "
    t = "World "
    v = s + t
    println(v)
    u = "and goodbye!"
    w = s + t + u
    println(w)
    x = "Hello "
    if s=="Hello " {
        println("Should print")
    }
    println("Ending string tests")
}
