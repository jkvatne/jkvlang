

func main() {
  y = 2.2
  printf("y=%f\n", y)
  assert(y>0.0, "Failed y>0")
  assert(y>=0.0, "Failed y>=0")
  assert(y<10.0, "Failed y<10")
  assert(y<=10.0, "Failed y<=10")
/*
  printf("The following should fail:\n")
  assert(y>10.0, "Failed y>10")
  assert(y>=10.0, "Failed y>=10")
  assert(y<0.0, "Failed y<0")
  assert(y<=0.0, "Failed y<=0")
  printf("\nNo more failures:\n")
*/
  printf("1.0/y=%f\n", 1.0/y)
  z = 1.0/y
  printf("z=%f\n", z)
  assert(1.0/y<0.454546 && 1.0/y>0.454544, "Failed 1.0/y=%f\n", 1.0/y)
  x = 1.1
  y = 2.2
  z = 3.3
  assert(false, "Should print 0.454545, got %f", 1.0/y)
  err = 0

  assert(1.0/y<0.454546 && 1.0/y>0.454544, "Failed 1.0/y=%f\n", 2.0)
  printf("1.0/y=%f\n", 1.0/y)
  printf("y/x=%f\n", y/x)
  printf("x/y=%f\n", x/y)
  printf("x+y=%f\n", x+y)
  w2 = x+y
  printf("w2=%f\n", w2)
  // The expression is not exactly equal to 3.3. Use > and <
  assert(w2>3.2999 && w2<3.30001, "Failed w2==3.3, got %f", w2)
  w4 = (0.5+(x+y)*z+0.5)
  printf("w4=%f\n", w4)
  assert(w4==11.89, "Failed, w4==11.89, got %f", w4)

  w2 = 0.1+z/x
  printf("w2=%f\n", w2)
  assert (w2>3.0999 && w2<3.1001,"Failed divide, got %f", w2)

  zero = 0.0
  w2 = x/zero
  printf("x/0.0=%f\n", w2)

  w = 1.0/y+(x+y/z)*(z*z*(x+y))
  printf("w=%f\n", w)
  assert (w>63.943244 && w<63.943246)

  w = x+1
}
