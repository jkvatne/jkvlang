

type Age = U8

type Person = struct {
  dummmy String
  name String
  adr String
  age Age
}

func main() {
    printf("Start test struct types\n")

    printf("1. Test struct\n")
    p = new(Person)
    p.name = "Jan Kåre Vatne"
    p.age = 70
    assert(p.age==70)
    assert(p.name=="Jan Kåre Vatne")

    printf("p.age=%d\n", p.age)
    printf("p.name=%s\n", p.name)

    printf("3. Test print utf\n")
    printf("Test utf: %s\n", "æøå")

    printf("4. Test type\n")
    var age Age
    age = 101
    printf("age=%d\n", age)
    assert(age==101)

}