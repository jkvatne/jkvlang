

type Age = U8

type Person = struct {
  no I32
  name String
  adr String
  age Age
}

func get_person(n I32) Person {
    p = new(Person)
    p.no = n
    return p
}

func main() {
    pers = get_person(123)
    printf("pers no=%d\n", pers.no)

