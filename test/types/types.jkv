

type Age = U8

type Person = struct {
  no I32
  name String
  adr String
  age Age
}

func get_person(n I32) Person {
    p = new(Person)
    p.no = n
    return p
}

func main() {
    printf("Start types.jkv\n")
    printf("1. Test struct\n")
    p = new(Person)
    p.age = 70
    p.name = "Jan Kåre Vatne"
    assert(p.age==70, "p.age was %d", p.age)
    fflush()
    assert(p.name=="Jan Kåre Vatne")
    fflush()
    printf("p.age=%d\n", p.age)
    fflush()
    printf("p.name=%s\n", p.name)
    fflush()

    printf("3. Test print utf\n")
    printf("Test utf: %s\n", "æøå")

    printf("4. Test type\n")
    var age Age
    age = 101
    printf("age=%d\n", age)
    assert(age==101)

    printf("5. Test struct returned from func\n")
    pers = get_person(123)
    printf("pers no=%d\n", pers.no)
}