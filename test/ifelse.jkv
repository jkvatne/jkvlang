
func main() {
    a = 1
    b = 2
    c = 3
    d = 0

    if b==6 {
        assert(false, "Error, b is not 6")
    } else if a==b  {
        assert(false, "Error, a is not equal to b")
    }

    // 1. Test if using ? and :
    if a>0 ? c+=2 : c+=1
    assert(c==5, "c+2 should be 5")

    // 2. Test simple if/else
    if a==1 {
       print("Selecting first if block")
    } else {
       assert(false, "Error, should select first block")
    }

    // 3. Test simple if/else
    if a==2 {
       assert(false, "3 Failed, should select second block")
    } else {
       d=1
    }
    assert(d==1)

    // "4. Test else if
    if b==6 {
        assert(false, "Error, b is not 6")
    } else if a==b  {
        assert(false, "Error, a is not equal to b")
    } else if b!=c {
        d=3
    } else {
        assert(false, "Error, else should not be selected")
    }
    assert(d==3)

    // 5. Single line if
    if b==2 ? c=4
    assert(c==4)

 }

