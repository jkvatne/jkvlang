/*
func foo(a F32, b F64) F32 {
    return (a+b)*(a-b)
}

func main () {
  w5 = foo(1.23, 3.45)
  assert w5==-10.3896
}
*/

func main() {
  // 1. Print a float litteral
  printf("Float=%f\n", 1.234)
  // 2. Print a single float variable
  a = 1.234
  printf("a=%f\n", a)
  // 3. Add two floats
  b = 2.345
  c = a + b
  printf("c=%f\n", c)
  // 4. Compare two floats
  d = 3.579
  assert(c==d,"Failed c==3.579")
  // 5. Compare float with constant
  assert(b==2.345,"Failed b==2.345")
  // 6. Compare constant with float
  assert(2.345==b,"Failed 2.345==b")
  // 5. Compare float with constant
  assert(b!=12.345,"Failed b!=2.345")
  // 6. Expression with const
  c = a + 1.0
  printf("a+1.0=%f\n", c)
  assert(c==2.234, "Failed c==2.234")
}