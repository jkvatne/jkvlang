/*
func foo(a F32, b F64) F32 {
    return (a+b)*(a-b)
}
*/

func main() {
    b = 2.345
    assert(2.345==b,"6. Failed 2.345==b")

    assert(false, "Line  8: Four numbers from 1 to 4: %d %d %d %d", 1, 2, 3, 4)
    if err==0 ? exit(1)
    assert(false, "Line 13: Four numbers from 1.0 to 4.0: %0.1f %0.1f %0.1f %0.1f", 1.0, 2.0, 3.0, 4.0)
    if err==0 ? return
    assert(false, "Line 15: Should be c=1.234:,  c=%0.3f", 1.234)
    if err==0 ? return
    c=1.234
    assert(false, "Line 18: Should be c=1.234:  c=%0.3f", c)
    if err==0 ? return
    assert(false, "Line 20: Should be c=1.234:  c=%0.3f", c)
    if err==0 ? return
    err=0
    // 1. Print a float literal
    printf("1. Float=%f\n", 1.234)
    // 2. Print a floats
    a = 1.234
    b = 2.345
    printf("28. a=%f\n", a)
    printf("29. a=%0.1f, const=%d\n", a, 111)
    printf("30. a=%0.3f, const=%d\n", a, 111)
    printf("31. a=%f, const=%d, float=%f\n", a, 111, 3.33)
    printf("32. a=%f, const=%d, float=%f\n", a, 111, b)
    // 3. Add two floats
    c = a + b
    printf("35. a=%f, b=%f, c=%f\n", a,b,c)
    // 4. Compare two floats
    d = 3.579
    assert(c==d,"38. Failed c==3.579")
    // 5. Compare float with constant
    // assert(b==2.345,"5. Failed b==2.345")
    printf("41. a=%f, b=%f, c=%f\n", a,b,c)
    // 6. Compare constant with float
    assert(2.345==b,"43. Failed 2.345==b")
    // 7. Compare float with constant
    assert(b!=12.345,"45. Failed b!=2.345")
    // 8. Expression with const
    c = a + 1.0
    printf("48. c=a+1.0=%f\n", c)
    assert(c==2.234, "49. Failed c==%f", c)
    assert(c==2.234, "50. Failed c==%f const=%d", c, 99)

    // 9. Compare with const
    assert(c>0.0, "53. Failed compare float >")
    assert(c>=0.0, "54. Failed compare float >=")
    assert(c<10.0, "55. Failed compare float <")
    assert(c<=10.0, "56. Failed compare float <=")
    // 10. Compre two variables
    assert(a<b, "58. Failed compare float %f<%f", a, b)
    assert(a<=b, "59. Failed compare float <=")
    assert(b==b, "60. Failed compare equal %f<%f", a, b)
    assert(b>a, "61. Failed compare float >")
    assert(b>=a, "62. Failed compare float >=")

}
