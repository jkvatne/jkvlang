const DONE I32 = 1

type RangeIterator = struct {
    start I64
    end I64
}

func range(start I32, end I32) RangeIterator {
    r = new(RangeIterator)
    r.start = start
    r.end = end
    return r
}

func next(r RangeIterator) I64 {
    if r.start>r.end ? fail(DONE)
    x = r.start
    r.start = x+1
    return x
}

func main() {
    for i = range(2,6) {
        printf("%d,", i)
    }
    print(";")

    r = range(1, 5)
    loop {
        i = next(r) else break
        printf("%d,", i)
        fflush()
    }
    print(";")
}