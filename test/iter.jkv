

func yield(x I32) Bool {
    return true
}

func from_to(start I32, end I32)  {
    i=start
    for {
        ok = yield(i)
        if !ok : break
        if i>=end : break
        i+=1
    }
}

func main() {
/*
    printf("Test iterations\n")
    for i=from_to(0,10) {
        printf("i=%d\n", i)
    }
*/
    printf("2. Test simple loop with break")
    i=1
    loop {
        printf("i=%d\n", i)
        i+=1
        if i>10 : break
    }

}