
func f1(s String) String {
    v = "f1 "+s
    return v+"."
    // Should free v now
}

func f0(s String) String {
    return "f0 "+s
}

func main() {
    printf("Start free.exe\n")
    assert(f0("xyz")=="f0 xyz")
    printf("f0 returned '%s'\n", f0("xyz"))
    assert(f1("xyz")=="f1 xyz.")
    printf("f1 returned '%s'\n", f1("xyz"))
}
