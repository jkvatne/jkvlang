
func f0(s String) String {
    return "f0 "+s
}

func f1(s String) String {
    v = "f1 "+s
    return v
}

func f2() String {
    return "f2"
}

func main() {
    printf("Start free.jkv\n")
    printf("1. Test call returning a string literal\n")
    fflush()
    assert(f2()=="f2", "Failed f2=='f2'")

    printf("2. Test free printed variable\n")
    s = "Hello "
    t = "World "
    v = s + t
    assert(v=="Hello World ", "Failed v=='Hello World '")

    printf("3. Test free result from f1\n")
    t = f1("xyz")
    assert(t=="f1 xyz", "Failed xyz==")

    printf("4. Test asserts\n")
    assert(f1("xyz")=="f1 xyz", "Failed f1()")
    assert(f0("xyz")=="f0 xyz", "Failed f0()")

}
