


func main() {

    x = 1.0
    i = I64(x)
    c = i & I64(0x7fff000000000000)
    c = c>>52
    print("Exponent for %f is %x", x, c)

    x = 1.0
    y = 1.00001
    z = y-x
    w = x-y
    i = I64(x+y) & I64(0x7fff000000000000)
    j = I64(w) & I64(0x7fff000000000000)
    print("0x%x 0x%x", i>>52, j>>52)
    e1 = i>>52
    e2 = j>>52
    print("0x%x 0x%x", e1, e2)
    print("de=%d", e2-e1)
    a = 15
    b = a >> 1
    assert(b==7)

    b = a<<2
    assert(b==60)

    // Operating on 64bit values
    ui = 0xabcdefab12345678
    uu = ui>>32
    ul = ui & 0xFFFFFFFF
    print("Splitting 0xabcdefab12345678 into %x and %x", uu, ul)
    print("Splitting 0xabcdefab12345678 into %x and %x", ui>>32, ui&0xFFFFFFFF)
}