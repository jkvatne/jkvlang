

type Age = U8

type Person = struct {
  no I32
  name String
  adr String
  age Age
}

func get_person(n I32) Person {
    p = new(Person)
    p.no = n
    return p
}

func main() {
    // 1. Test struct
    p = new(Person)
    p.age = 70
    p.name = "Jan Kåre Vatne"
    assert(p.age==70, "p.age was %d", p.age)
    assert(p.name=="Jan Kåre Vatne")

    // 2. Test print utf
    print("Test utf: %s", "æøå")

    // 3. Test type
    var age Age
    age = 101
    assert(age==101)

    // 4. Test struct returned from func
    pers = get_person(123)
    assert(pers.no==123)
}