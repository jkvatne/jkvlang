
func main() {
    a = 1
    b = 2
    c = 3
    printf(" 1. Starting tests of if/else\n")

    assert(true, "Should not be printed")
    if a>0 ? c+=2 : c+=1
    assert(c==5, "c+2 should be 5")

    if a==1 {
       printf(" 2. Selecting first if block\n")
    } else {
       assert(false, "Error, should select first block")
    }

    if a!=1 {
       assert(false, "Error, should select else block")
    } else {
       printf(" 3. Selecting else block\n")
    }

    if b==6 {
        assert(false, "Error, b is not 6")
    } else if a==b  {
        assert(false, "Error, a is not equal to b")
    } else if b!=c {
        printf(" 4. Ok, b!=c\n")
    } else {
        assert(false, "Error, else should not be selected")
    }
    printf(" 5. Ended multiple else statements")
 }

