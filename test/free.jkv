
func f0(s String) String {
    return "f0 "+s
}

func f1(s String) String {
    v = "f1 "+s
    return v
}

func f2() String {
    return "f2"
}

func main() {
    // Test call returning a string literal
    assert(f2()=="f2", "Failed f2=='f2'")

    // Test free printed variable
    s = "Hello "
    t = "World "
    w = s + t
    assert(w=="Hello World ", "Failed v=='Hello World '")

    // Test free result from f1
    t = f1("xyz")
    assert(t=="f1 xyz", "Failed xyz==")

    // Test calling f1 from assert
    assert(f1("xyz")=="f1 xyz", "Failed f1()")
    assert(f0("xyz")=="f0 xyz", "Failed f0()")

}
