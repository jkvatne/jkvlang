

type Age = U8

type Person = struct {
  no I32
  name String
  adr String
  age Age
  inc U8
}


func update(p Person) {
    p.age+= p.inc
}

func decr_age(p Person) {
    p.age-=p.inc
}

func main() {
    p = new(Person)
    p.age = 70
    p = new(Person)
    assert(p.age==0, "p.age should be 0, was %d", p.age)
/*
    p.age = 70
