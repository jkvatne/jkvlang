

type Age = U8

type Person = struct {
  no I32
  name String
  adr String
  age Age
  inc U8
}


func update(p Person) {
    p.age+=p.inc
}

func main() {
    p = new(Person)
    p.name = "Jan Kåre Vatne"
    p.age = 70
    p.inc = 1
    p.age = p.inc + p.age

    assert(p.age==71, "Failed, p.age was %d, not 71", p.age)
    p.inc = 1
    p.age = p.inc + p.age
    assert(p.age==72, "Failed, p.age was %d not 72", p.age)
    assert(p.name=="Jan Kåre Vatne")

    p.inc = 2
}