func shortfunc() I32 {
    s = 24
    s = s/6

    z=3

    z+=4
    z*=8
    return s+z
}

func fi(a Bool, c I32) I32 {
    if a ? c+=1 : c+=2
    return c
}

func fa(a Bool, c I32) I32 {
    if a {
        c+=1
    } else {
        c-=1
    }
    return c
}

func test_fi()  {
    r = fi(true, 30)
    assert r==31
}



