
func gg(a Bool, c I32) I32 {
    if a ? c+=2 : c+=1
    return c
}

func test_g()  {
    r = gg(true, 30)
    assert(r==32, "Failed 6")
}

func mpy(x I32, y I32) I32 {
   return x*y
}

func sum(x I32, y I32) I32 {
   return x+y
}

func f2() I32 {
    return sum(2,3)+mpy(4,5)  // = (2+3) + (4*5) = 25
}

func f3() I32 {
    return 25
}

func main() {

    // Test nested integer functions
    w = sum(3, mpy(4,5))   // = 23
    assert(w==23, "Failed 1")

    // Test functions without parameters
    assert(f3()==25)
    assert(f2()==25)
    assert(f2()==21,"Intentionaly failed 4 : f2()==21, got %d", f2())
    invert_err()

    // Test divide
    y = 3
    assert(13/y==4, "Failed  13/y")


    // Test simple integer function call
    x = sum(1,2)
    assert(x==3, "Failed sum(1,2)")


    // Test function call inside assert and with integer arg to assert
    assert(f2()==25,"Failed 3 : f2()==25, got %d", f2())

    // Test nested functions
    assert(gg(true, f2())==27, "Failed nested functions")

    // Test div and mod
    x = 13
    y = 3
    assert(x%3==1, "Failed x%%3")
    assert(13%3==1, "Failed 13%%3")
    assert(x/y==4, "Failed x/y")
    assert(x/3==4, "Failed x/3")
    assert(13/3==4, "Failed 13/3")
    assert(x%y==1, "Failed x%%y")
    assert(13/y==4, "Failed  13/y")
    assert(13%y==1, "Failed 13%%y")
}
